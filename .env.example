# Database
DATABASE_URL=postgresql+asyncpg://fleet:fleet@localhost:5432/fleet_api

# Server
FLEET_API_HOST=0.0.0.0
FLEET_API_PORT=8000

# Limits (RFC 1 defaults)
FLEET_TASK_RETENTION_DAYS=30
FLEET_RETASK_MAX_DEPTH=10
FLEET_DELEGATION_MAX_DEPTH=4
FLEET_HEARTBEAT_TIMEOUT_SECONDS=300
FLEET_PAUSE_TTL_SECONDS=3600
